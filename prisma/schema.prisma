generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            Int            @id @default(autoincrement())
  name          String
  logoUrl       String?
  createdAt     DateTime       @default(now())
  users         User[]
  tasks         Task[]
  leaves        Leave[]
  attendance    Attendance[]
  auditLogs     AuditLog[]
  toolUsageLogs ToolUsageLog[]
  chatRooms     ChatRoom[]
  messages      Message[]
  products      Product[]
  buyers        Buyer[]
  suppliers     Supplier[]
  shipments     Shipment[]
  payments      Payment[]
  documents     Document[]
}

model User {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  password        String?
  googleId        String?          @unique
  role            Role             @default(EMPLOYEE)
  department      String?
  avatar          String?
  phone           String?
  organizationId  Int
  organization    Organization     @relation(fields: [organizationId], references: [id])
  isActive        Boolean          @default(true)
  sessionToken    String?
  lastSeen        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tasks           Task[]
  attendance      Attendance[]
  leaves          Leave[]
  auditLogs       AuditLog[]
  toolUsageLogs   ToolUsageLog[]
  sentMessages    Message[]        @relation("MessageSender")
  chatRoomMembers ChatRoomMember[]
  readReceipts    MessageRead[]

  @@index([organizationId])
  @@index([email])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

model Attendance {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id])
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  loginTime      DateTime
  logoutTime     DateTime?
  totalHours     Float?
  date           String
  isLate         Boolean      @default(false)
  autoClosedAt   DateTime?
  createdAt      DateTime     @default(now())

  @@index([userId, date])
  @@index([organizationId, date])
}

model Task {
  id                 Int          @id @default(autoincrement())
  title              String
  description        String?
  userId             Int
  user               User         @relation(fields: [userId], references: [id])
  organizationId     Int
  organization       Organization @relation(fields: [organizationId], references: [id])
  deadline           DateTime
  priority           Priority     @default(MEDIUM)
  status             TaskStatus   @default(PENDING)
  progressPercentage Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([userId])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Leave {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id])
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  leaveType      String
  startDate      DateTime
  endDate        DateTime
  reason         String?
  status         LeaveStatus  @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([userId])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model AuditLog {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id])
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  action         String
  metadata       Json?
  timestamp      DateTime     @default(now())

  @@index([organizationId, timestamp])
}

model ToolUsageLog {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id])
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  toolId         String
  toolName       String
  action         String       @default("OPENED")
  createdAt      DateTime     @default(now())

  @@index([userId, toolId])
}

model ChatRoom {
  id             Int              @id @default(autoincrement())
  name           String?
  type           ChatRoomType     @default(GROUP)
  description    String?
  organizationId Int
  organization   Organization     @relation(fields: [organizationId], references: [id])
  createdById    Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  members        ChatRoomMember[]
  messages       Message[]

  @@index([organizationId])
}

enum ChatRoomType {
  GROUP
  PRIVATE
}

model ChatRoomMember {
  id         Int       @id @default(autoincrement())
  roomId     Int
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  role       RoomRole  @default(MEMBER)
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  @@unique([roomId, userId])
  @@index([userId])
}

enum RoomRole {
  ADMIN
  MEMBER
}

model Message {
  id             Int           @id @default(autoincrement())
  content        String?
  type           MessageType   @default(TEXT)
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  fileMimeType   String?
  roomId         Int
  room           ChatRoom      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId       Int
  sender         User          @relation("MessageSender", fields: [senderId], references: [id])
  organizationId Int
  organization   Organization  @relation(fields: [organizationId], references: [id])
  isEdited       Boolean       @default(false)
  editedAt       DateTime?
  isDeleted      Boolean       @default(false)
  deletedAt      DateTime?
  replyToId      Int?
  replyTo        Message?      @relation("MessageReply", fields: [replyToId], references: [id])
  replies        Message[]     @relation("MessageReply")
  readBy         MessageRead[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([roomId, createdAt])
  @@index([senderId])
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

model MessageRead {
  id        Int      @id @default(autoincrement())
  messageId Int
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
}

model Product {
  id             Int            @id @default(autoincrement())
  name           String
  sku            String?
  category       String?
  description    String?
  unit           String         @default("KG")
  pricePerUnit   Float
  stockQuantity  Float          @default(0)
  minStockLevel  Float          @default(0)
  isActive       Boolean        @default(true)
  organizationId Int
  organization   Organization   @relation(fields: [organizationId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  shipmentItems  ShipmentItem[]

  @@index([organizationId])
}

model Buyer {
  id             Int          @id @default(autoincrement())
  name           String
  company        String?
  country        String       @default("UAE")
  email          String?
  phone          String?
  address        String?
  taxId          String?
  notes          String?
  isActive       Boolean      @default(true)
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  shipments      Shipment[]
  payments       Payment[]

  @@index([organizationId])
}

model Supplier {
  id             Int          @id @default(autoincrement())
  name           String
  company        String?
  country        String       @default("India")
  email          String?
  phone          String?
  address        String?
  gstNumber      String?
  notes          String?
  isActive       Boolean      @default(true)
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  shipments      Shipment[]

  @@index([organizationId])
}

model Shipment {
  id              Int            @id @default(autoincrement())
  shipmentNumber  String         @unique
  buyerId         Int
  buyer           Buyer          @relation(fields: [buyerId], references: [id])
  supplierId      Int?
  supplier        Supplier?      @relation(fields: [supplierId], references: [id])
  organizationId  Int
  organization    Organization   @relation(fields: [organizationId], references: [id])
  origin          String         @default("India")
  destination     String
  portOfLoading   String?
  portOfDischarge String?
  containerType   String?
  grossWeight     Float?
  netWeight       Float?
  vesselName      String?
  etd             DateTime?
  eta             DateTime?
  actualDeparture DateTime?
  actualArrival   DateTime?
  invoiceValue    Float?
  freightCost     Float?
  totalCost       Float?
  sellingPrice    Float?
  profit          Float?
  status          ShipmentStatus @default(DRAFT)
  paymentStatus   PaymentStatus  @default(PENDING)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           ShipmentItem[]
  documents       Document[]
  payments        Payment[]

  @@index([organizationId, status])
  @@index([buyerId])
}

enum ShipmentStatus {
  DRAFT
  CONFIRMED
  IN_TRANSIT
  CUSTOMS_HOLD
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

model ShipmentItem {
  id          Int      @id @default(autoincrement())
  shipmentId  Int
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Float
  unit        String
  unitPrice   Float
  totalPrice  Float

  @@index([shipmentId])
}

model Payment {
  id             Int           @id @default(autoincrement())
  shipmentId     Int?
  shipment       Shipment?     @relation(fields: [shipmentId], references: [id])
  buyerId        Int?
  buyer          Buyer?        @relation(fields: [buyerId], references: [id])
  organizationId Int
  organization   Organization  @relation(fields: [organizationId], references: [id])
  amount         Float
  currency       String        @default("USD")
  paymentDate    DateTime?
  dueDate        DateTime?
  method         String?
  reference      String?
  status         PaymentStatus @default(PENDING)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, status])
  @@index([shipmentId])
}

model Document {
  id             Int          @id @default(autoincrement())
  title          String
  type           DocType
  fileUrl        String
  fileName       String
  fileSize       Int?
  mimeType       String?
  shipmentId     Int?
  shipment       Shipment?    @relation(fields: [shipmentId], references: [id])
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  uploadedById   Int
  notes          String?
  createdAt      DateTime     @default(now())

  @@index([organizationId, type])
}

enum DocType {
  INVOICE
  PACKING_LIST
  BILL_OF_LADING
  CERTIFICATE_OF_ORIGIN
  PHYTOSANITARY
  LC
  CUSTOMS_CLEARANCE
  OTHER
}
