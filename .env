# ============================================================
# backend/.env — Copy this: cp .env.example .env
# Fill in your real values. NEVER commit this file.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Local: postgresql://postgres:YOUR_PASS@localhost:5432/atoz_ems
# Supabase: get from Project > Settings > Database > URI
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/atoz_ems"

# ── JWT ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="atoz-global-secret-key-2026"
JWT_EXPIRES_IN="8h"

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Security ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
AUTO_LOGOUT_HOURS=10
LATE_LOGIN_HOUR=9
LATE_LOGIN_MINUTE=15

# ── CORS: your frontend URL ───────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Initial admin (used by seed.js) ──────────────────────────
ADMIN_INITIAL_EMAIL=admin@atozglobal.com
ADMIN_INITIAL_PASSWORD=ChangeMe@2026!

# ── Google OAuth (optional) ───────────────────────────────────
# Get from: console.cloud.google.com > APIs > Credentials > OAuth 2.0
# Authorized origins: http://localhost:3000 (dev), https://your-app.vercel.app (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email notifications (optional) ───────────────────────────
# Gmail App Password: myaccount.google.com > Security > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_NAME=A to Z Global EMS
FROM_EMAIL=noreply@atozglobal.com

# ── PRODUCTION (Railway) ──────────────────────────────────────
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# NODE_ENV=production
# CLIENT_URL=https://your-app.vercel.app
# BCRYPT_ROUNDS=12
